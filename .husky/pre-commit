#!/usr/bin/env sh
# Exit immediately if any command fails. Without this, a lint-staged
# failure would be ignored because the version-sync check below would
# still run and its exit status would overwrite the script's overall
# exit code. The user's spec didn't include `set -e` but the spec's
# intent was clearly "lint-staged failure blocks the commit" (Test 2).
set -e

# ─── Credential leak prevention (v8.17.0 / Ship 5+1 hardening) ─────────
# This repo is PUBLIC on GitHub. The pre-commit hook scans staged ADDED
# lines for credential-shaped strings and blocks the commit on match.
#
# Patterns checked:
#   • High-entropy provider tokens: AWS (AKIA…), Stripe (sk_live_…),
#     GitHub PAT (ghp_…), Google OAuth (ya29.…), Anthropic (sk-…)
#   • Suspicious var names with a quoted value >=8 chars:
#     SMOKE_PASSWORD, FIREBASE_PRIVATE_KEY, ADMIN_PASSWORD,
#     SERVICE_ACCOUNT_KEY, GITHUB_TOKEN, password, secret,
#     client_secret, access_token
#
# NOT checked (intentional):
#   • tests/e2e/setup/fixtures/** — emulator-only synthetic data
#   • The pattern definition in this hook itself
#
# Per INC-2026-05-21-001 lesson: AIzaSy* + Sentry sntr*_ shapes were
# previously "intentionally NOT checked" (public-by-design Firebase
# Web apiKey). The credential-leak incident proved that classification
# was wrong — even semi-public keys are sensitive in source control.
# AIzaSy[A-Za-z0-9_-]{30,} and sntr[a-z]{1,2}_[A-Za-z0-9+/=._-]{40,}
# are now blocked unconditionally. Walkthroughs use placeholder
# syntax: <copy-from-firebase-console> / <paste-your-DSN-here>.
#
# False-positive override (use with caution):
#   git commit --no-verify
#
# To refine: edit LEAK_PATTERNS below. After edit, sanity-test by
# staging a fake credential and confirming the hook blocks.

LEAK_PATTERNS="(AKIA[0-9A-Z]{16}|sk_live_[0-9a-zA-Z]{20,}|ghp_[0-9a-zA-Z]{30,}|ya29\\.[0-9A-Za-z_-]{30,}|sk-[A-Za-z0-9]{40,}|AIzaSy[A-Za-z0-9_-]{30,}|sntr[a-z]{1,2}_[A-Za-z0-9+/=._-]{40,}|(SMOKE_PASSWORD|FIREBASE_PRIVATE_KEY|ADMIN_PASSWORD|SERVICE_ACCOUNT_KEY|GITHUB_TOKEN|password|secret|client_secret|access_token)[[:space:]]*[:=][[:space:]]*[\"'][^\"']{8,}[\"'])"

LEAK_HITS=$(git diff --cached --unified=0 \
  -- ':!tests/e2e/setup/fixtures/**' ':!.husky/pre-commit' \
  | grep -E '^\+[^+]' \
  | grep -inE "$LEAK_PATTERNS" || true)

if [ -n "$LEAK_HITS" ]; then
  echo ""
  echo "POTENTIAL CREDENTIAL LEAK DETECTED IN STAGED CHANGES"
  echo ""
  echo "A pattern matched something that looks like a credential."
  echo ""
  echo "Matched lines:"
  echo "$LEAK_HITS" | head -10
  echo ""
  echo "Options:"
  echo "  1. Remove the credential, use environment variable instead"
  echo "  2. If false positive (schema field name, doc text, etc.),"
  echo "     refine the LEAK_PATTERNS regex in .husky/pre-commit"
  echo "  3. Override (NOT RECOMMENDED): git commit --no-verify"
  echo ""
  exit 1
fi
# ─── End credential leak prevention ────────────────────────────────────

npx lint-staged

# Version sync check — mirrors v7.8.1 Hook 5, but fires for any
# git commit from anywhere (including outside Claude Code).
#
# v7.9.8 — aligned sed regex with the Claude Code hook's permissive
# pattern ([^"]+) so semver pre-release identifiers (8.0.0-rc1,
# 1.2.3-beta, etc.) parse correctly. The prior ([0-9.]+) regex
# rejected anything with a hyphen, blocking pre-release version
# bumps. No behavior change for plain semver (7.9.7 → 7.9.7 still
# matches); strictly a bug fix that widens acceptance.
UTILS_VER=$(grep 'APP_VERSION' src/core/utils.js | head -1 | \
  sed -E 's/.*"([^"]+)".*/\1/')
PKG_VER=$(node -p "require('./package.json').version")
if [ "$UTILS_VER" != "$PKG_VER" ]; then
  echo "ERROR: APP_VERSION ($UTILS_VER) in utils.js does not match"
  echo "       package.json version ($PKG_VER)"
  echo "Fix version drift before committing."
  exit 1
fi

# Dashboard smoke gate — runs ONLY when dashboard-relevant files staged.
# Founder standard 2026-05-21: dashboard gets the same level of audit/smoke
# as the app. Catches regressions before they land on main.
#
# Triggers on changes to:
#   - templates/dashboards/**
#   - docs/reports/**  (renderer scripts emit here)
#   - scripts/regen-*.py
#   - scripts/aggregate-*.py
#   - tests/dashboard-smoke/**
DASHBOARD_PATHS=$(git diff --cached --name-only -- \
  'templates/dashboards/**' \
  'docs/reports/**' \
  'scripts/regen-*.py' \
  'scripts/aggregate-*.py' \
  'tests/dashboard-smoke/**' 2>/dev/null)

if [ -n "$DASHBOARD_PATHS" ]; then
  echo "[dashboard-smoke] dashboard files staged — running smoke gate..."

  # Sync staged templates → docs/reports BEFORE smoke runs.
  # docs/reports/*.html is gitignored (Founder-local-only), but the smoke
  # asserts against rendered HTML. A staged template change must be reflected
  # in docs/reports before smoke can pass.
  for t in templates/dashboards/*.template.html; do
    base=$(basename "$t" .template.html)
    target="docs/reports/${base}.html"
    if [ -f "$target" ]; then
      cp "$t" "$target"
    fi
  done
  # Re-run regen scripts so data blocks are repopulated post-sync.
  # 2026-05-21 Founder root-cause: regen-sessions + regen-founder-checklist MUST
  # be here. Pre-commit copies templates (containing {} empty) to docs/reports/.
  # If a regen isn't run here, the file stays empty after commit until
  # post-commit fires ~5s later. That window is when Founder saw "blank page".
  for s in regen-activity regen-amendments regen-app-health regen-dashboard regen-escalations regen-index regen-main-flows regen-proposals regen-token-usage regen-sessions regen-session-detail regen-founder-checklist; do
    if [ -f "scripts/$s.py" ]; then
      python "scripts/$s.py" > /dev/null 2>&1 || true
    fi
  done
  # dry-run-regen-ops-views.py writes proposals/amendments/escalations/discussion-bubbles
  # data blocks. Same root-cause class as sessions/founder-checklist — template overwrites
  # zeroed the file until next post-commit. Repopulate inside pre-commit window.
  if [ -f "scripts/dry-run-regen-ops-views.py" ]; then
    python scripts/dry-run-regen-ops-views.py > /dev/null 2>&1 || true
  fi
  # Dashboard freshness sentinel — detects empty payloads + count mismatches
  # (e.g. ships_today=0 when ship-progress has today's entries) + auto-repairs.
  # Writes .claude/state/aggregates/dashboard-freshness.json which the dashboard
  # reads to show a red banner if any page can't be auto-repaired.
  if [ -f "scripts/dashboard-freshness-sentinel.py" ]; then
    python scripts/dashboard-freshness-sentinel.py > /dev/null 2>&1 || true
  fi

  if ! node tests/dashboard-smoke/run.js > /tmp/dashboard-smoke-precommit.log 2>&1; then
    echo ""
    echo "ERROR: dashboard smoke failed. Tail of log:"
    tail -20 /tmp/dashboard-smoke-precommit.log
    echo ""
    echo "Run: npm run smoke:dashboards"
    echo "Fix the failures before committing."
    exit 1
  fi
  echo "[dashboard-smoke] OK"
fi

# Secret-scan gate (post-INC-2026-05-21-001 credential-leak prevention).
# Runs secretlint against staged TEXT files only. Blocks commit if any
# credential pattern is detected. Skips binaries, lockfiles, and generated
# dashboard output (docs/reports/ is regen-driven, not Founder-authored).
STAGED_TEXT=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | grep -E '\.(md|html|js|ts|jsx|tsx|json|yml|yaml|ps1|sh|py)$' | grep -v 'package-lock\.json' | grep -v '^docs/reports/' || true)
if [ -n "$STAGED_TEXT" ] && [ -f ".secretlintrc.json" ] && [ -d node_modules/secretlint ]; then
    if ! echo "$STAGED_TEXT" | tr '\n' '\0' | xargs -0 npx --no-install secretlint --secretlintignore .gitignore --maskSecrets > /tmp/secretlint-precommit.log 2>&1; then
        echo ""
        echo "ERROR: secretlint detected credentials in staged files. Tail of log:"
        tail -20 /tmp/secretlint-precommit.log
        echo ""
        echo "See .claude/state/incidents/2026-05-21-credential-leak.md for context."
        echo "If false positive, scope an exception in .secretlintrc.json."
        exit 1
    fi
    echo "[secret-scan] OK"
fi

# Encoding hygiene (post-INC-2026-05-21-002 action item #4).
# .ps1 and .py files MUST be pure ASCII unless they carry an explicit
# `# noqa: encoding` comment. PowerShell 5.1 silent-converts smart
# quotes / em-dashes / non-breaking spaces on write, which produces
# silent runtime failures (`cron-2026-05-21-encoding-failure` log).
ENC_STAGED=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | grep -E '\.(ps1|py)$' || true)
if [ -n "$ENC_STAGED" ]; then
    ENC_HITS=""
    for f in $ENC_STAGED; do
        if [ -f "$f" ]; then
            if grep -qE "# noqa: encoding|# *encoding-ok" "$f" 2>/dev/null; then
                continue
            fi
            # Check for non-ASCII bytes (LC_ALL=C makes grep treat input as bytes)
            if LC_ALL=C grep -lP '[\x80-\xff]' "$f" > /dev/null 2>&1; then
                ENC_HITS="$ENC_HITS$f\n"
            fi
        fi
    done
    if [ -n "$ENC_HITS" ]; then
        printf "\nERROR: non-ASCII characters in staged .ps1/.py file(s):\n"
        printf "$ENC_HITS"
        echo "PowerShell 5.1 / older Python encoding handlers convert smart"
        echo "quotes / em-dashes silently. Replace with ASCII equivalents OR"
        echo "add '# noqa: encoding' to the file if intentional (e.g. unicode"
        echo "in a test fixture)."
        echo ""
        echo "See .claude/state/incidents/2026-05-21-process-failures.md item #4."
        exit 1
    fi
    echo "[encoding-check] OK"
fi
