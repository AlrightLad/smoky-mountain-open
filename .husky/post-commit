#!/usr/bin/env sh
# post-commit — dashboard freshness per commit (AMD-019, husky-managed).
#
# Git's core.hooksPath is set to .husky/_ (by Husky), so the legacy hook
# at .git/hooks/post-commit DOES NOT FIRE. This is the live hook.
#
# Scope split (dashboard health agent owns this hook):
#   - Runs the dashboard regen subset (NOT regen-main-flows.py — main-flows
#     polish agent owns that surface).
#   - AMD-020 Class A auto-clean: commits the dashboard regen output so it
#     does not accumulate in the working tree.
#   - Auto-commit uses "cron(routine):" prefix → next hook fire bails via
#     the recursion guard below.
#   - Does NOT push (push remains AMD-018 agent-decided).
#
# Synchronous: the founder's commit waits for regen+auto-commit so the
# local dashboard at file:///.../docs/reports/dashboard.html reflects the
# new commit before any next action.

set -e
cd "$(git rev-parse --show-toplevel)"

# Locate python early (needed by both recursion-guard heartbeat refresh and
# main regen path). Mirrors regen-all.sh discovery order.
PY=""
for c in \
    "$LOCALAPPDATA/Programs/Python/Python312/python.exe" \
    "$LOCALAPPDATA/Programs/Python/Python311/python.exe" \
    "/usr/bin/python3" \
    "/usr/local/bin/python3"; do
    if [ -x "$c" ] >/dev/null 2>&1 || command -v "$c" >/dev/null 2>&1; then
        PY="$c"; break
    fi
done
if [ -z "$PY" ]; then
    PY=$(command -v python3 2>/dev/null || command -v python 2>/dev/null || echo "python")
fi

# Recursion guard: my own auto-commit re-fires this hook. Bail on
# cron(routine) / decision-apply commits so we don't loop the full regen.
#
# 2026-05-19 heartbeat-redundancy fix (Path 1): the prior version exited
# 0 here WITHOUT refreshing the heartbeat. Result: the watcher cron's
# 5-min auto-commit fired this hook every cycle but never updated the
# heartbeat, so it went 19+ hours stale despite the system being alive.
# We now write a fast-path heartbeat (status=PASS-COMMIT, source=post-
# commit-hook-fast, duration=0) on every cron(routine) commit before
# exiting. The full-regen heartbeat below still writes on real commits
# and wins because it lands later. This means: as long as ANY commit
# happens (including 5-min watcher auto-commits), the heartbeat stays
# fresh.
HEAD_MSG=$(git log -1 --pretty=%s 2>/dev/null || echo "")
case "$HEAD_MSG" in
    "cron(routine)"*|"Apply proposal decisions"*|"Apply amendment decisions"*|"Apply escalation decisions"*|"cron: "*)
        if [ -f "scripts/write-regen-heartbeat.py" ]; then
            HEARTBEAT_STATUS="PASS-COMMIT" \
            HEARTBEAT_SOURCE="post-commit-hook-fast" \
            HEARTBEAT_DURATION="0" \
            "$PY" scripts/write-regen-heartbeat.py >/dev/null 2>&1 || true
        fi
        exit 0
        ;;
esac

# Read ship_id from current-ship.json (per ESC-003 Approach A)
SHIP_PATH=".claude/state/current-ship.json"
SHIP_ID=""
if [ -f "$SHIP_PATH" ]; then
    SHIP_ID=$("$PY" -c "
import json
try:
    d = json.load(open('$SHIP_PATH'))
    print(d.get('ship_id') or '', end='')
except Exception:
    print('', end='')
" 2>/dev/null || echo "")
fi

# Emit team-work summary event (best-effort)
if [ -f "scripts/emit-team-work-summary.py" ]; then
    EMIT_ARGS="--agent engineer --tokens 0 --note post-commit-hook"
    if [ -n "$SHIP_ID" ]; then
        EMIT_ARGS="$EMIT_ARGS --ship-id $SHIP_ID"
    fi
    "$PY" scripts/emit-team-work-summary.py $EMIT_ARGS >/dev/null 2>&1 || true
fi

# R1+R2 (2026-05-15): scaffold docs/reports/ from tracked templates first.
# Idempotent (no-op when scaffolds exist), bootstraps fresh checkouts.
SCAFFOLD_LOG=".claude/state/dashboard-health/post-commit-hook.log"
mkdir -p "$(dirname "$SCAFFOLD_LOG")"
SCAFFOLD_TS="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
{
    echo "=== post-commit hook fired $SCAFFOLD_TS HEAD=$(git rev-parse --short HEAD) ==="
} > "$SCAFFOLD_LOG"

if [ -f "scripts/scaffold-from-templates.sh" ]; then
    if ! bash scripts/scaffold-from-templates.sh >> "$SCAFFOLD_LOG" 2>&1; then
        echo "[post-commit] WARN scaffold-from-templates failed — see $SCAFFOLD_LOG" >&2
    fi
fi

# Regenerate dashboard subset. Order matters: aggregates before consumers.
#
# R1 (2026-05-15): exit codes captured to SCAFFOLD_LOG instead of swallowed
# via "|| true". Hook still exits 0 (commits succeed even on regen errors)
# but failures are now visible via post-commit-hook.log + the FAILED list
# emitted to stderr. The audit lesson: a silent regen pipeline is what let
# the dashboard vanish unnoticed for hours.
#
# BUG-2 fix (2026-05-16): regen-main-flows.py REINSTATED. The prior exclusion
# (intent: main-flows polish agent owns visual surface) had an unintended
# consequence: when main-flows-data.json updates, no one runs the data-block
# swap, leaving <script id="report-data">{}</script> and a blank page.
# The polish agent owns visual iteration on the template; the regen script
# owns the mechanical data-block swap. Different concerns, both required.
REGEN_SCRIPTS="\
scripts/scan-shipped-proposals.py
scripts/aggregate-telemetry.py
scripts/ingest-session-transcripts.py
scripts/aggregate-token-usage.py
scripts/aggregate-test-health.py
scripts/aggregate-security-health.py
scripts/aggregate-approvals-pipeline.py
scripts/aggregate-architecture-review.py
scripts/aggregate-fiq-status.py
scripts/aggregate-self-tests.py
scripts/inject-health-banners.py
scripts/regen-proposals.py
scripts/regen-amendments.py
scripts/regen-escalations.py
scripts/regen-dashboard.py
scripts/regen-main-flows.py
scripts/regen-activity.py
scripts/dry-run-regen-ops-views.py
scripts/regen-token-usage.py
scripts/consolidate-lighthouse.py
scripts/aggregate-app-health.py
scripts/regen-app-health.py
scripts/regen-index.py"

FAILED=""
for s in $REGEN_SCRIPTS; do
    if [ -f "$s" ]; then
        echo "" >> "$SCAFFOLD_LOG"
        echo "--- $s ---" >> "$SCAFFOLD_LOG"
        if ! "$PY" "$s" >> "$SCAFFOLD_LOG" 2>&1; then
            FAILED="$FAILED $s"
        fi
    fi
done

if [ -n "$FAILED" ]; then
    echo "[post-commit] WARN regen failures:$FAILED" >&2
    echo "[post-commit] see $SCAFFOLD_LOG for diagnostics" >&2
fi

# 2026-05-19 heartbeat-redundancy fix (Path 1): write the regen heartbeat
# right after the dashboard regen loop completes. status=PASS when every
# regen script returned 0, GATE-FAIL when any failed. source=post-commit-
# hook lets the dashboard distinguish hook-driven refreshes from the
# scheduled daily-maintenance task (which used to be the only writer).
# This guarantees the heartbeat refreshes on EVERY real commit, closing
# the 19+ hour stale gap that the daily-maintenance task's misses caused.
if [ -f "scripts/write-regen-heartbeat.py" ]; then
    if [ -n "$FAILED" ]; then
        HEARTBEAT_STATUS="GATE-FAIL"
    else
        HEARTBEAT_STATUS="PASS"
    fi
    HEARTBEAT_STATUS="$HEARTBEAT_STATUS" \
    HEARTBEAT_SOURCE="post-commit-hook" \
    HEARTBEAT_DURATION="0" \
    "$PY" scripts/write-regen-heartbeat.py >> "$SCAFFOLD_LOG" 2>&1 || true
fi

# 2026-05-21 — Standing orchestration checks (per docs/dashboard-troubleshooting.md).
# These run on every commit + emit health JSON the dashboard consumes.
#
# (1) Cron task health (PowerShell, runs on Windows only — POSIX no-op).
if command -v powershell.exe >/dev/null 2>&1; then
    powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "
        \$ErrorActionPreference = 'Continue'
        \$tasks = Get-ScheduledTask -TaskName 'PARBAUGHS*' -ErrorAction SilentlyContinue
        \$results = @()
        foreach (\$t in \$tasks) {
          \$info = Get-ScheduledTaskInfo -TaskName \$t.TaskName
          \$results += [pscustomobject]@{
            name = \$t.TaskName
            state = \$t.State.ToString()
            hidden = [bool]\$t.Settings.Hidden
            run_level = \$t.Principal.RunLevel.ToString()
            last_result = \$info.LastTaskResult
            last_run = if (\$info.LastRunTime) { \$info.LastRunTime.ToUniversalTime().ToString('yyyy-MM-ddTHH:mm:ssZ') } else { \$null }
          }
        }
        \$report = [ordered]@{
          schema_version = 'cron-health-v1'
          generated_at = (Get-Date).ToUniversalTime().ToString('yyyy-MM-ddTHH:mm:ssZ')
          status = 'green'
          tasks = \$results
        }
        \$report | ConvertTo-Json -Depth 6 | Out-File -FilePath '.claude/state/aggregates/cron-health.json' -Encoding utf8
    " >/dev/null 2>&1 || true
fi

# (2) Repo secret scan (fast — only flags new committed secrets).
if [ -f "scripts/scan-repo-secrets.js" ]; then
    node scripts/scan-repo-secrets.js >/dev/null 2>&1 || true
fi

# (3) Bug Triage Listener — categorize feature_requests P0-P3.
if [ -f "scripts/cron/bug-triage-listener.py" ]; then
    "$PY" scripts/cron/bug-triage-listener.py >/dev/null 2>&1 || true
fi

# (4) Dashboard smoke (post-commit, NON-blocking — log only).
# Runs on every commit so we always have a fresh dashboard-smoke-latest.json
# on the dashboard surface. Failures here don't block (pre-commit already gated
# dashboard-touching commits); this just keeps the dashboard's smoke card live.
if [ -f "tests/dashboard-smoke/run.js" ]; then
    node tests/dashboard-smoke/run.js > /tmp/dashboard-smoke-postcommit.log 2>&1 || true
fi

# Phase T1 D34 — P9.5 automated truthfulness self-check.
# Asserts that session-transcript ingestion + aggregator produce non-zero
# output when source files are present. Catches silent data-loss bugs
# where the aggregator runs successfully but emits zeros.
if [ -f "scripts/ingest-session-transcripts.py" ]; then
    echo "" >> "$SCAFFOLD_LOG"
    echo "--- P9.5 self-test ---" >> "$SCAFFOLD_LOG"
    if ! "$PY" scripts/ingest-session-transcripts.py --self-test >> "$SCAFFOLD_LOG" 2>&1; then
        echo "[post-commit] FAIL P9.5 truthfulness self-test (see $SCAFFOLD_LOG)" >&2
        # Self-test failures are loud but non-blocking — the commit already
        # landed. Surface to stderr for visibility; let cron route this
        # into test-health.json on the next refresh.
    fi
fi

# AMD-020 Class A auto-clean. Commit ONLY dashboard regen output. Exclude
# docs/reports/main-flows.html and .claude/state/main-flows-v2/* — owned
# by main-flows polish agent. Exclude any modifications outside the
# allowlist (source code, configs, etc.) — those belong to the agent who
# made the original commit.
CLASS_A_PATHS="\
docs/reports/dashboard.html
docs/reports/amendments.html
docs/reports/proposals.html
docs/reports/escalations.html
docs/reports/activity.html
docs/reports/token-usage.html
docs/reports/discussion-bubbles.html
docs/reports/design-system.html
docs/reports/index.html
docs/reports/app-health.html
.claude/state/telemetry/aggregates
.claude/state/telemetry/events
.claude/state/dashboard-health
.claude/state/aggregates
.claude/state/heartbeats"

DIRTY=""
for p in $CLASS_A_PATHS; do
    if [ -e "$p" ]; then
        if ! git diff --quiet HEAD -- "$p" 2>/dev/null; then
            DIRTY="$DIRTY $p"
        fi
    fi
done

if [ -n "$DIRTY" ]; then
    for f in $DIRTY; do
        git add -- "$f" 2>/dev/null || true
    done
    # Only commit if there are actual staged changes (defensive — stat-only
    # dirty paths may have nothing real to commit).
    if ! git diff --cached --quiet 2>/dev/null; then
        GIT_AUTHOR_NAME="PARBAUGHS Dashboard Agent" \
        GIT_AUTHOR_EMAIL="dashboard@parbaughs.local" \
        GIT_COMMITTER_NAME="PARBAUGHS Dashboard Agent" \
        GIT_COMMITTER_EMAIL="dashboard@parbaughs.local" \
        git commit -m "cron(routine): post-commit dashboard regen (AMD-019 + AMD-020 Class A auto-clean)" >/dev/null 2>&1 || true
    fi
fi

exit 0
