  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-version-sync.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-commit-lint.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/push-protection.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/gate-assertions.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/gate-protected.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/secrets-scanner.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/schema-mutation-alarm.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/governance-protection.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/skill-approval-gate.sh"
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/hook-14-mcp-health-check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-syntax.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/hook-12-console-log-edit.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/hook-13-design-quality.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/encoding-hygiene.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-continue.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-verification.sh",
            "blocking": false
          }
        ]
      }
    ]
  }
}
