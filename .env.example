# Smoke automation credentials — copy to .env.local and fill with real values
# This file (.env.example) is committed; .env.local is gitignored
# Get real values from password manager (NEVER from a committed file)

# Test account credentials (dedicated hidden account in Smoke Test League)
SMOKE_EMAIL=your-test-account@example.com
SMOKE_PASSWORD=

# Test league + account identifiers
SMOKE_LEAGUE_ID=
SMOKE_USER_UID=

# Dev server URL (optional override; default is http://localhost:5173/smoky-mountain-open/)
# DEV_URL=http://localhost:5173/smoky-mountain-open/
