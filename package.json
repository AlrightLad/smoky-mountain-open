{
  "name": "the-parbaughs",
  "version": "8.25.234",
  "private": true,
  "scripts": {
    "dev": "vite",
    "hq": "node scripts/serve-hq.mjs",
    "build": "vite build",
    "build:staging": "vite build --base=/",
    "preview": "vite preview",
    "lint": "eslint src/ scripts/ --ext .js",
    "verify": "node scripts/verify.js",
    "verify:ci": "node scripts/verify.js --json --fail-fast",
    "verify:drift": "node scripts/verify.js --check=global-vs-scoped",
    "verify:display": "node scripts/verify.js --check=display-drift",
    "verify:cleanup": "node scripts/verify.js --confirm-cleanup",
    "emulator:start": "firebase emulators:start --import=./emulator-data --export-on-exit",
    "emulator:seed": "node tests/e2e/setup/seed-baseline.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:rules": "node tests/firestore-rules/v8-rules.spec.js",
    "smoke": "node tests/smoke/run.js",
    "smoke:full": "cross-env BROWSERS=chromium,firefox,webkit,webkit-mobile node tests/smoke/run.js",
    "smoke:headed": "cross-env HEADED=1 node tests/smoke/run.js",
    "smoke:debug": "cross-env HEADED=1 SLOWMO=500 DEVTOOLS=1 node tests/smoke/run.js",
    "smoke:dashboards": "node tests/dashboard-smoke/run.js",
    "smoke:all": "npm run smoke && npm run smoke:dashboards",
    "errors:prod": "node scripts/prod-errors.mjs",
    "rules:deploy:staging": "node scripts/seed-deploy-rules.mjs parbaughs-staging",
    "rules:deploy:prod": "node scripts/seed-deploy-rules.mjs parbaughs",
    "ship-gate": "node scripts/ship-gate.js",
    "prepare": "husky",
    "lint:fix": "eslint src/ scripts/ --ext .js --fix",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "knip": "knip --reporter compact",
    "jscpd": "jscpd src functions",
    "lighthouse": "lhci autorun",
    "bundle:scan": "node scripts/scan-bundle.js",
    "scan:secrets": "secretlint --secretlintignore .gitignore \"**/*\"",
    "scan:secrets:fast": "secretlint --secretlintignore .gitignore \"src/**/*\" \"functions/**/*\" \"public/**/*\" \"scripts/**/*\"",
    "security:pentest": "node scripts/security/pentest-harness.mjs",
    "test:capacitor": "playwright test --config=playwright.capacitor.config.js",
    "visual:bless": "node tests/visual-regression/bless.mjs",
    "visual:check": "node tests/visual-regression/run.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
    "@sentry/browser": "^10.53.1",
    "@vitest/coverage-v8": "^4.1.7",
    "acorn": "^8.16.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "firebase-admin": "^13.8.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jscpd": "^4.2.3",
    "knip": "^6.14.1",
    "lint-staged": "^16.4.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "secretlint": "13.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "chalk": "^4.1.2"
  },
  "lint-staged": {
    "src/**/*.js": "npm run lint",
    "tests/**/*.js": "npm run lint",
    "scripts/**/*.js": "npm run lint"
  }
}
